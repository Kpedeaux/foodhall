# ── REQUIRED IN PRODUCTION ───────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-64-byte-hex-secret-here

# ── Database (Postgres) ──────────────────────────────────────
# On App Platform, bind a DigitalOcean Managed Postgres component and
# reference it as: ${db.DATABASE_URL} so the platform injects the URL.
# Local dev: spin up Postgres with Docker and use the URL below.
#   docker run --name fh-pg -e POSTGRES_PASSWORD=dev -p 5432:5432 -d postgres:16
DATABASE_URL=postgres://postgres:dev@localhost:5432/postgres

# SSL mode: 'require' (production), 'prefer' (dev), 'disable' (no SSL).
# Auto-detected from NODE_ENV; override with this if needed.
# DATABASE_SSL=require

# Connection pool size (default 10).
# PG_POOL_MAX=10

# ── Square integration ──────────────────────────────────────
# Required for any Square-backed feature (sales pull, etc.)
SQUARE_ACCESS_TOKEN=your-square-access-token
SQUARE_ENVIRONMENT=sandbox            # or "production"

# ── CORS (comma-separated origins) ──────────────────────────
# Required in production. App Platform domain + any custom domain.
# CORS_ORIGINS=https://foodhall-api-xxxx.ondigitalocean.app,https://yourdomain.com

# ── Server ───────────────────────────────────────────────────
# PORT is injected automatically on App Platform; only set locally.
# PORT=3001
# NODE_ENV=production

# ── Proxy (for rate limiting behind nginx/Cloudflare/DO LB) ─
# 1 = trust one proxy hop (App Platform's load balancer)
# TRUST_PROXY=1

# ── First-boot seed (only used when markets table is empty) ─
# REQUIRED on first deploy. The server refuses to seed without it.
# Must be 12+ chars and NOT "changeme" / "strochadmin".
INITIAL_ADMIN_PASSWORD=replace-with-a-strong-password
# INITIAL_ADMIN_USERNAME=ashley
# INITIAL_ADMIN_EMAIL=ashley@example.com
# INITIAL_MARKET_NAME=St. Roch Market

# ── SQLite → Postgres import (one-shot, dev/migration only) ─
# Path to the OLD SQLite database file to import from.
# Used only by `npm run migrate-from-sqlite`.
# LEGACY_SQLITE_PATH=./server/data/food-hall.db

# ── Super Admin bootstrap (optional) ──────────────────────────
# On first boot, if no super_admin user exists in the database AND both
# of these are set, a super_admin user is created using these values.
# After the first super admin exists, these env vars become no-ops and
# may be removed. The password must be 12+ chars.
#
# INITIAL_SUPER_ADMIN_USERNAME=kevin-super
# INITIAL_SUPER_ADMIN_PASSWORD=use-a-strong-passphrase-please
